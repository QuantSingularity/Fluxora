# Fluxora Environment Configuration
# Copy to .env and fill in your values
# NEVER commit .env to version control

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=INFO

# ── Database ─────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD
MYSQL_DATABASE=fluxoradb
MYSQL_USER=appuser
MYSQL_PASSWORD=CHANGE_ME_STRONG_APP_PASSWORD

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── Application Secrets ───────────────────────────────────────
# JWT_SECRET must be at least 32 random characters
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS
# ENCRYPTION_KEY must be exactly 32 bytes
ENCRYPTION_KEY=CHANGE_ME_ENCRYPTION_KEY_32BYTES
API_KEY=CHANGE_ME_API_KEY

# ── Grafana ──────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ── Docker Images (for production) ───────────────────────────
BACKEND_IMAGE=ghcr.io/fluxora/backend:latest
FRONTEND_IMAGE=ghcr.io/fluxora/frontend:latest
