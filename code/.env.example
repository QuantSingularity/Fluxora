# ──────────────────────────────────────────────────────────────────────────────
# Fluxora Backend – Environment Configuration
# Copy to .env and update values before starting the server.
# ──────────────────────────────────────────────────────────────────────────────

# ── Environment ───────────────────────────────────────────────────────────────
ENV=production
# Set to "development" to enable hot-reload and debug logging.

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./fluxora.db
# PostgreSQL example:
# DATABASE_URL=postgresql://user:password@localhost:5432/fluxora

# ── Security ──────────────────────────────────────────────────────────────────
# IMPORTANT: Replace with a strong random secret (at least 32 characters).
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_BEFORE_PRODUCTION_USE_MINIMUM_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Model ─────────────────────────────────────────────────────────────────────
MODEL_PATH=./fluxora_model.joblib
MODEL_VERSION=0.1.0
MODEL_TYPE=random_forest

# ── Feature Store ─────────────────────────────────────────────────────────────
FEATURE_STORE_PATH=./config/feature_store

# ── Monitoring ────────────────────────────────────────────────────────────────
MONITORING_ENABLED=true
METRICS_PORT=9090
DRIFT_THRESHOLD=0.25

# ── Service Registry (Consul – optional) ──────────────────────────────────────
# SERVICE_REGISTRY_URL=http://consul:8500
# SERVICE_PORT=8000
