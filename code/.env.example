# ── Application ───────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# ── Security (CHANGE THESE IN PRODUCTION) ─────────────────────────────────────
SECRET_KEY=change-this-secret-key-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./fluxora.db
# DATABASE_URL=postgresql://user:password@localhost:5432/fluxora
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ── Model ─────────────────────────────────────────────────────────────────────
MODEL_PATH=./fluxora_model.joblib
MODEL_VERSION=0.1.0
MODEL_TYPE=random_forest
MODEL_MAX_DEPTH=6
MODEL_ETA=0.3

# ── Monitoring ────────────────────────────────────────────────────────────────
MONITORING_ENABLED=true
DRIFT_THRESHOLD=0.25
METRICS_PORT=9090
